<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    @Styles.Render("~/bundles/css/base")
    @RenderSection("Styles", false)
    @Scripts.Render("~/bundles/js/base/preload")
</head>
<body class="d-flex flex-column min-vh-100 bg-body-tertiary">
<div class="d-flex flex-nowrap flex-grow-1">
    <!-- Sidebar -->
    <aside class="sidebar d-flex flex-column flex-shrink-0 p-3 bg-body border-end">
        <div class="text-center mb-3">
            <a href="@Url.Action("Index")" class="d-block">
                <img src="~/Content/images/profile.jpg" alt="Logo"
                     class="sidebar-logo rounded-circle object-fit-cover shadow">
            </a>
        </div>
        <hr>
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a href="@Url.Action("Index")" class="nav-link">
                    <i class="bi bi-house me-2 regular-icon"></i>
                    <i class="bi bi-house-fill me-2 filled-icon"></i>
                    Home
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Upload")" class="nav-link">
                    <i class="bi bi-file-earmark-arrow-up me-2 regular-icon"></i>
                    <i class="bi bi-file-earmark-arrow-up-fill me-2 filled-icon"></i>
                    Upload
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("History")" class="nav-link">
                    <i class="bi bi-cloud-upload me-2 regular-icon"></i>
                    <i class="bi bi-cloud-upload-fill me-2 filled-icon"></i>
                    History
                </a>
            </li>
        </ul>
        <hr>
        <div class="dropdown">
            <a href="#" class="d-flex align-items-center link-body-emphasis text-decoration-none dropdown-toggle"
               data-bs-toggle="dropdown" aria-expanded="false">
                <img src="~/Content/images/profile.jpg" alt="User" width="32" height="32" class="rounded-circle me-2">
                <strong>mdo</strong>
            </a>
            <ul class="dropdown-menu text-small shadow">
                <li><a class="dropdown-item" href="#">Settings</a></li>
                <li>
                    <hr class="dropdown-divider">
                </li>
                <li>
                    <button class="dropdown-item" onclick="logout()">Logout</button>
                </li>
            </ul>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="vstack">
        <main class="flex-grow-1 p-3">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>
        <hr/>
        <footer>
            <p class="text-center text-muted">Philippine National Bank</p>
        </footer>
    </div>
</div>
@Scripts.Render("~/bundles/js/base")
@RenderSection("Scripts", required: false)
</body>
</html>