<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    @Styles.Render("~/bundles/css/base")
    @RenderSection("Styles", false)
    @Scripts.Render("~/bundles/js/base/preload")
</head>
<body class="d-flex flex-column min-vh-100">
<div class="wrapper d-flex flex-nowrap flex-grow-1">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header text-center mb-3">
            <a href="@Url.Action("Index")" class="d-block">
                <img src="~/Content/images/profile.jpg" alt="Logo" class="sidebar-logo rounded-circle">
            </a>
        </div>
        <hr>
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a href="@Url.Action("Index")" class="nav-link" data-nav-id="home">
                    <i class="bi bi-house me-2 regular-icon"></i>
                    <i class="bi bi-house-fill me-2 filled-icon d-none"></i>
                    Home
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Upload")" class="nav-link" data-nav-id="upload">
                    <i class="bi bi-file-earmark-arrow-up me-2 regular-icon"></i>
                    <i class="bi bi-file-earmark-arrow-up-fill me-2 filled-icon d-none"></i>
                    Upload
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("History")" class="nav-link" data-nav-id="history">
                    <i class="bi bi-cloud-upload me-2 regular-icon"></i>
                    <i class="bi bi-cloud-upload-fill me-2 filled-icon d-none"></i>
                    History
                </a>
            </li>
        </ul>
        <hr>
        <div class="dropdown">
            <a href="#" class="d-flex align-items-center link-body-emphasis text-decoration-none dropdown-toggle"
               data-bs-toggle="dropdown" aria-expanded="false">
                <img src="~/Content/images/profile.jpg" alt="User" width="32" height="32" class="rounded-circle me-2">
                <strong>mdo</strong>
            </a>
            <ul class="dropdown-menu text-small shadow">
                <li><a class="dropdown-item" href="#">Settings</a></li>
                <li>
                    <hr class="dropdown-divider">
                </li>
                <li>
                    <button class="dropdown-item" onclick="logout()">Logout</button>
                    @* <a class="dropdown-item" href="#">Logout</a> *@
                </li>
            </ul>
        </div>
    </aside>
    <!-- Main Content -->
    <div class="d-flex flex-column flex-grow-1 min-vh-100">
        <main class="content flex-grow-1">
            <div class="container-fluid p-3">
                @RenderBody()
            </div>
        </main>
        @* <footer class="footer py-3"> *@
        @*     <div class="container-fluid"> *@
        @*         <p class="align-content-center">Philippine National Bank</p> *@
        @*     </div> *@
        @* </footer> *@
    </div>
</div>
@Scripts.Render("~/bundles/js/base")
@RenderSection("Scripts", required: false)
</body>
</html>