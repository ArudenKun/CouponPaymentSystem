@*             const linkPath = link.getAttribute('href').toLowerCase(); *@
@*             if (currentPath.includes(linkPath) || *@
@*                 (currentPath === '/' && link.dataset.navId === 'home')) { *@
@*                 link.classList.add('active'); *@
@*             } *@
@*         }); *@
@*     }); *@
@* </script> *@
</body>
</html>